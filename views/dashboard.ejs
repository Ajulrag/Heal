<%- include('layout/header') %>
<%- include('layout/sidebar') %>

<main class="main">
  <header class="topbar">
    <div class="topbar-left">
      <h2 class="page-title">Dashboard</h2>
      <div class="current-patient-info" id="currentPatientInfo">
        <!-- Current patient info will be displayed here -->
      </div>
    </div>
    <div class="user">
      <span class="user-icon"><i class="fas fa-user-md"></i></span>
      <span class="user-name">Dr. Alex Morgan</span>
    </div>
  </header>

  <section id="views">
    <!-- DASHBOARD -->
    <section id="dashboard" class="view">
      <div class="dashboard-grid">
        <!-- PATIENT STATUS + UV -->
        <div class="card card-status">
          <div class="status-top">
            <div class="status-info">
              <div class="status-icon" id="healthIcon"><i class="fas fa-heartbeat"></i></div>
              <div>
                <h3 id="healthLabel">HEALTHY</h3>
                <p class="muted">Last update: <span id="lastUpdate">—</span></p>
                <p class="muted">Patient: <span id="currentPatientName">—</span></p>
              </div>
            </div>
            <div class="uv-panel" id="uvCard">
              <span class="uv-label">UV LIGHT</span>
              <span class="uv-value" id="uvStatus">OFF</span>
              <span class="uv-next">Next: <span id="nextSchedule">—</span></span>
              <span class="uv-duration" id="uvDuration">Duration: --</span>
            </div>
          </div>
        </div>

        <!-- VITALS -->
        <div class="card card-vitals">
          <h4><i class="fas fa-heart"></i> Vitals</h4>
          <div class="vitals-grid">
            <div class="vital temp">
              <span class="vital-title"><i class="fas fa-thermometer-half"></i> Temperature</span>
              <span class="vital-value" id="tempVal">-- °C</span>
              <span class="vital-desc" id="tempDesc">—</span>
            </div>
            <div class="vital">
              <span class="vital-title"><i class="fas fa-tint"></i> Moisture</span>
              <span class="vital-value" id="moistVal">-- %</span>
              <span class="vital-desc" id="moistDesc">—</span>
            </div>
          </div>
        </div>

        <!-- CHART -->
        <div class="card card-chart">
          <div class="chart-header" style="display:flex;justify-content:space-between;align-items:center;">
            <h4 style="margin:0"><i class="fas fa-chart-line"></i> Trends (1 day)</h4>
            <div style="display:flex;gap:10px;align-items:center;">
              <label class="muted" for="rangeSelect">Range</label>
              <select id="rangeSelect">
                <option value="1m">1 min</option>
                <option value="3m">3 min</option>
                <option value="5m">5 min</option>
                <option value="10m">10 min</option>
                <option value="30m">30 min</option>
                <option value="1h">1 hour</option>
                <option value="5h">5 hours</option>
                <option value="10h">10 hours</option>
                <option value="1d">1 day</option>
                <option value="7d">7 days</option>
                <option value="30d">30 days</option>
                <option value="3mo">3 months</option>
                <option value="6mo">6 months</option>
                <option value="1y">1 year</option>
                <option value="all">All time</option>
              </select>
            </div>
          </div>
          <div class="chart-container">
            <div id="trendChart"></div>
          </div>
        </div>

        <!-- CONTROLS -->
        <div class="card card-controls">
          <h4><i class="fas fa-cogs"></i> Treatment Control</h4>
          <div class="controls-grid">
            <div class="control-buttons">
              <button class="btn start" id="btnStartUV"><i class="fas fa-play"></i> Start UV</button>
              <button class="btn stop" id="btnStopUV"><i class="fas fa-stop"></i> Stop UV</button>
            </div>
            <div class="schedule-box">
              <label><i class="far fa-clock"></i> Schedule (mins)</label>
              <div class="schedule-inputs">
                <input id="scheduleMins" type="number" min="1" value="5" />
                <button class="btn schedule" id="btnSchedule"><i class="fas fa-calendar-plus"></i> Set</button>
              </div>
            </div>
            <div class="manual-duration-box">
              <label><i class="fas fa-hourglass-half"></i> Manual Duration (secs)</label>
              <div class="duration-inputs">
                <input id="manualDuration" type="number" min="5" max="300" value="60" />
                <button class="btn duration" id="btnSetDuration"><i class="fas fa-check"></i> Set</button>
              </div>
            </div>
          </div>
          <small class="muted">Manual controls simulate hardware actions.</small>
        </div>

        <!-- QUICK ACTIONS -->
        <div class="card card-actions">
          <h4><i class="fas fa-bolt"></i> Quick Actions</h4>
          <div class="actions-grid">
            <button class="action-btn" id="quickPrescription">
              <i class="fas fa-prescription-bottle-alt"></i>
              <span>New Prescription</span>
            </button>
            <button class="action-btn" id="quickReport">
              <i class="fas fa-file-medical-alt"></i>
              <span>Generate Report</span>
            </button>
            <button class="action-btn" id="quickAlert">
              <i class="fas fa-bell"></i>
              <span>Send Alert</span>
            </button>
            <button class="action-btn" id="quickAnalyze">
              <i class="fas fa-chart-bar"></i>
              <span>Analyze Data</span>
            </button>
          </div>
        </div>

        <!-- LOGS -->
        <div class="card card-logs">
          <h4><i class="fas fa-clipboard-list"></i> Recent Logs</h4>
          <div class="logs-container">
            <div class="logs" id="logList">—</div>
          </div>
          <div class="logs-actions">
            <button class="btn small" id="downloadCSV"><i class="fas fa-download"></i> <span>Download CSV</span></button>
            <button class="btn small" id="clearLogs"><i class="fas fa-trash"></i> <span>Clear Logs</span></button>
          </div>
        </div>
      </div>
    </section>

    <!-- PATIENTS -->
    <section id="patients" class="view hidden">
      <div class="card full">
        <div class="card-header responsive-header">
          <h3><i class="fas fa-procedures"></i> Patient Management</h3>
          <button class="btn" id="addPatientBtn"><i class="fas fa-plus"></i> <span>Add Patient</span></button>
        </div>
        <div class="patients-grid" id="patientsList">
          <!-- Patients will be dynamically added here -->
        </div>
      </div>
    </section>

    <!-- PRESCRIPTIONS -->
    <section id="prescriptions" class="view hidden">
      <div class="card full">
        <div class="card-header responsive-header">
          <h3><i class="fas fa-prescription-bottle"></i> Prescriptions & Recommendations</h3>
          <button class="btn" id="newPrescriptionBtn"><i class="fas fa-plus"></i> <span>New Prescription</span></button>
        </div>
        
        <div class="prescription-form card hidden" id="prescriptionForm">
          <h4>Create New Prescription</h4>
          <div class="form-grid">
            <div class="form-group">
              <label for="patientSelect">Patient</label>
              <select id="patientSelect">
                <option value="">Select Patient</option>
              </select>
            </div>
            <div class="form-group">
              <label for="prescriptionDate">Date</label>
              <input type="date" id="prescriptionDate">
            </div>
          </div>
          <div class="form-group">
            <label for="medication">Medication & Dosage</label>
            <textarea id="medication" placeholder="Enter medication details and dosage instructions..."></textarea>
          </div>
          <div class="form-group">
            <label for="instructions">Treatment Instructions</label>
            <textarea id="instructions" placeholder="Enter specific treatment instructions..."></textarea>
          </div>
          <div class="form-group">
            <label for="notes">Additional Notes</label>
            <textarea id="notes" placeholder="Any additional notes or recommendations..."></textarea>
          </div>
          <div class="form-actions responsive-actions">
            <button class="btn" id="savePrescription"><i class="fas fa-save"></i> <span>Save Prescription</span></button>
            <button class="btn secondary" id="cancelPrescription"><i class="fas fa-times"></i> <span>Cancel</span></button>
          </div>
        </div>
        
        <div class="prescriptions-list" id="prescriptionsList">
          <!-- Prescriptions will be dynamically added here -->
        </div>
      </div>
    </section>

    <!-- TREATMENT -->
    <section id="treatment" class="view hidden">
      <div class="card full">
        <h3><i class="fas fa-stethoscope"></i> Treatment History</h3>
        <div class="treatment-stats">
          <div class="stat-card">
            <div class="stat-value" id="totalTreatments">0</div>
            <div class="stat-label">Total Treatments</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="avgDuration">0</div>
            <div class="stat-label">Avg Duration (min)</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="successRate">0%</div>
            <div class="stat-label">Success Rate</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="autoTreatments">0</div>
            <div class="stat-label">Auto Treatments</div>
          </div>
        </div>
        <div class="table-container">
          <table class="table responsive-table" id="treatmentTable">
            <thead>
              <tr>
                <th>#</th>
                <th>Patient</th>
                <th>Started</th>
                <th>Stopped</th>
                <th>Duration (s)</th>
                <th>Mode</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ALERTS -->
    <section id="alerts" class="view hidden">
      <div class="card full">
        <div class="card-header responsive-header">
          <h3><i class="fas fa-bell"></i> Alerts & Notifications</h3>
          <div class="alert-filters">
            <button class="btn small active" data-filter="all">All</button>
            <button class="btn small" data-filter="critical">Critical</button>
            <button class="btn small" data-filter="warning">Warning</button>
            <button class="btn small" data-filter="info">Info</button>
          </div>
        </div>
        <div id="alertsList" class="alerts-list">
          <!-- Alerts will be dynamically added here -->
        </div>
        <button class="btn small" id="clearAlerts" style="margin-top:12px;"><i class="fas fa-trash"></i> <span>Clear All Alerts</span></button>
      </div>
    </section>

    <!-- SETTINGS -->
    <section id="settings" class="view hidden">
      <div class="card full">
        <h3><i class="fas fa-cog"></i> Settings</h3>
        <div class="settings-grid">
          <div class="setting">
            <label>Temperature threshold (°C)</label>
            <input id="thTemp" type="number" step="0.1" value="38.0" />
          </div>
          <div class="setting">
            <label>Moisture threshold (%)</label>
            <input id="thMoist" type="number" step="1" value="80" />
          </div>
          <div class="setting toggle">
            <label>Auto enable UV</label>
            <label class="switch">
              <input type="checkbox" id="autoUvEnabled" checked>
              <span class="slider"></span>
            </label>
          </div>
          <div class="setting">
            <label>Observation interval (minutes)</label>
            <input id="observationInterval" type="number" min="1" value="5" />
          </div>
        </div>
        
        <div class="settings-actions responsive-actions">
          <button class="btn" id="applySettings"><i class="fas fa-save"></i> <span>Apply Settings</span></button>
          <button class="btn secondary" id="resetSettings"><i class="fas fa-undo"></i> <span>Reset defaults</span></button>
        </div>
      </div>
    </section>
  </section>

  <footer class="footer">
    <div><i class="fas fa-shield-alt"></i> Doctor Dashboard • Prototype • Not for clinical use</div>
  </footer>
</main>

<script src="/js/dashboard.js"></script>

<%- include('layout/footer') %>